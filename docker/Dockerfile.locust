FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt locust

COPY tests/locustfile.py /mnt/locust/locustfile.py

WORKDIR /mnt/locust

EXPOSE 8089

CMD ["locust", "-f", "locustfile.py", "--host", "http://web:8000"]