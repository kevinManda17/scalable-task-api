# Django Configuration
SECRET_KEY=your-django-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database Configuration
POSTGRES_DB=taskapi
POSTGRES_USER=taskapi_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS Configuration (for deployment)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# ECS Configuration (for deployment)
ECS_CLUSTER_NAME=task-api-cluster
ECS_SERVICE_NAME=task-api-service
ECS_TASK_DEFINITION=task-api-task

# Network Configuration (for deployment)
SUBNET_IDS=subnet-12345,subnet-67890
SECURITY_GROUP_ID=sg-123456