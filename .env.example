# ==================== DJANGO CONFIGURATION ====================
# Secret key for Django - MUST be changed in production!
SECRET_KEY=your-django-secret-key-here-change-this-in-production

# Debug mode - Set to False in production
DEBUG=False

# Allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL Database settings
POSTGRES_DB=taskapi_db
POSTGRES_USER=taskapi_user
POSTGRES_PASSWORD=your-secure-database-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==================== CACHE CONFIGURATION ====================
# Redis settings
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TIMEOUT=300

# ==================== JWT AUTHENTICATION ====================
# JWT token lifetime settings
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ==================== EMAIL CONFIGURATION ====================
# Email backend for notifications (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ==================== AWS CONFIGURATION ====================
# AWS credentials for deployment
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name

# ==================== ECS CONFIGURATION ====================
# ECS settings for deployment
ECS_CLUSTER_NAME=task-api-cluster
ECS_SERVICE_NAME=task-api-service
ECS_TASK_DEFINITION=task-api-task-definition
ECS_CONTAINER_NAME=taskapi

# ==================== VPC CONFIGURATION ====================
# VPC and networking configuration
SUBNET_IDS=subnet-12345678,subnet-87654321
SECURITY_GROUP_ID=sg-12345678

# ==================== LOGGING CONFIGURATION ====================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
DJANGO_LOG_FILE=/var/log/django/app.log

# ==================== SECURITY SETTINGS ====================
# Secure SSL redirect (set to True in production with HTTPS)
SECURE_SSL_REDIRECT=False

# CSRF settings
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True

# Session settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True

# ==================== CELERY & ASYNC TASKS ====================
# Celery task queue settings
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ==================== APPLICATION SETTINGS ====================
# Application-specific settings
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
API_PAGINATION_SIZE=20
API_THROTTLE_RATE=1000/hour

# ==================== MONITORING & OBSERVABILITY ====================
# Error tracking (Sentry, etc.)
SENTRY_DSN=

# ==================== DEVELOPMENT SETTINGS ====================
# Development overrides
DEVELOPMENT_MODE=False
MOCK_EXTERNAL_APIS=False

# ==================== TESTING SETTINGS ====================
# Test environment settings
TEST_RUNNER=django.test.runner.DiscoverRunner
